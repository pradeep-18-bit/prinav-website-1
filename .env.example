ASPNETCORE_ENVIRONMENT=Production
FRONTEND_PORT=80
BACKEND_PORT=8080

# Leave blank when the frontend should call the backend through the same host,
# for example http://<ec2-public-ip>/api via the Nginx reverse proxy.
VITE_API_ORIGIN=
VITE_DEV_API_TARGET=http://localhost:5000

ConnectionStrings__DefaultConnection=Server=your-db-host;Port=3306;Database=your-db-name;User=your-db-user;Password=your-db-password;SslMode=None;

JwtSettings__Key=replace-with-a-long-random-secret
JwtSettings__Issuer=PirnavAPI
JwtSettings__Audience=PirnavClient
JwtSettings__DurationInMinutes=60

EmailSettings__SmtpServer=smtp.example.com
EmailSettings__Port=465
EmailSettings__SenderName=Pirnav Careers
EmailSettings__SenderEmail=no-reply@example.com
EmailSettings__Password=replace-with-smtp-password
EmailSettings__HrEmail=hr@example.com
